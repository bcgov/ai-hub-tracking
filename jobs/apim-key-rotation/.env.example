# =============================================================================
# Container App Job — Environment Variables Example
# =============================================================================
# Copy to .env for local testing with `python main.py`.
# In production these are injected by Terraform via Container App Job env config.
# =============================================================================

# Required — set by Terraform
ENVIRONMENT=dev
APP_NAME=ai-services-hub
SUBSCRIPTION_ID=<your-azure-subscription-id>

# Optional overrides (default: derived from APP_NAME + ENVIRONMENT)
# RESOURCE_GROUP=ai-services-hub-dev
# APIM_NAME=ai-services-hub-dev-apim
# HUB_KEYVAULT_NAME=ai-services-hub-dev-hkv

# Rotation behaviour
ROTATION_ENABLED=true
ROTATION_INTERVAL_DAYS=7
DRY_RUN=true

# Key Vault secret expiry (≤ 90 for BC Gov Landing Zone policy)
SECRET_EXPIRY_DAYS=90
