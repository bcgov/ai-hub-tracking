<policies>
    <inbound>
        <base />
%{ if tracking_dimensions_enabled ~}
        <!-- Extract tracking dimensions from headers -->
        <include-fragment fragment-id="tracking-dimensions" />
%{ endif ~}
        <!-- Tenant identification -->
        <set-header name="X-Tenant-Id" exists-action="override">
            <value>${tenant_name}</value>
        </set-header>
%{ if openai_enabled && rate_limiting_enabled ~}
        <!-- Per-model token rate limiting for OpenAI requests only -->
        <!-- Each model has its own rate limit matching its Azure OpenAI deployment capacity -->
        <!-- Only applies to /openai/* paths; DocInt/Speech/Search/Storage are not rate-limited by token count -->
        <!-- CRITICAL: estimate-prompt-tokens reads the entire request body for tokenization. -->
        <!-- On large binary payloads (e.g., 500KB base64 DocInt images) this causes APIM to hang. -->
        <!-- Extracts deployment name from URL: /openai/deployments/{deployment-name}/... -->
        <!-- For /v1/ format: extracts from request body "model" field (deployment name lookup key) -->
        <choose>
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;openai&quot;))">
                <set-variable name="deploymentName" value="@{
                    var path = context.Request.Url.Path;
                    var match = System.Text.RegularExpressions.Regex.Match(path, @&quot;/deployments/([^/]+)/&quot;);
                    if (match.Success) { return match.Groups[1].Value; }
                    // For /v1/ format: model field is the deployment name lookup key on Azure OpenAI
                    // Client sends e.g. "gpt-4.1-mini"; use bare model name to match deployment names
                    // NOTE: do NOT prepend tenant prefix here — rate-limit <when> conditions compare
                    // against bare deployment names from tfvars (e.g. "gpt-4.1-mini", not "tenant-gpt-4.1-mini").
                    // URL rewriting (further below) adds the tenant prefix independently for backend routing.
                    if (path.ToLower().Contains(&quot;/v1/&quot;)) {
                        try {
                            var body = context.Request.Body.As&lt;JObject&gt;(preserveContent: true);
                            var model = body?[&quot;model&quot;]?.ToString();
                            if (!string.IsNullOrEmpty(model)) { return model; }
                        } catch { }
                    }
                    return &quot;unknown&quot;;
                }" />
                <choose>
%{ for model in model_deployments ~}
                    <when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;deploymentName&quot;, &quot;&quot;) == &quot;${model.name}&quot;)">
                        <!-- Rate limit for ${model.name}: ${model.capacity}k TPM (deployment capacity is in thousands of TPM) -->
                        <llm-token-limit
                            counter-key="@(context.Subscription.Id + &quot;-${model.name}&quot;)"
                            tokens-per-minute="${model.capacity * 1000}"
                            estimate-prompt-tokens="true"
                            remaining-tokens-variable-name="remainingTokens"
                            remaining-tokens-header-name="x-ratelimit-remaining-tokens"
                            tokens-consumed-variable-name="tokensConsumed" />
                    </when>
%{ endfor ~}
                    <otherwise>
                        <!-- Fallback rate limit for unknown models: ${tokens_per_minute} TPM -->
                        <llm-token-limit
                            counter-key="@(context.Subscription.Id + &quot;-unknown&quot;)"
                            tokens-per-minute="${tokens_per_minute}"
                            estimate-prompt-tokens="true"
                            remaining-tokens-variable-name="remainingTokens"
                            remaining-tokens-header-name="x-ratelimit-remaining-tokens"
                            tokens-consumed-variable-name="tokensConsumed" />
                    </otherwise>
                </choose>
            </when>
        </choose>
%{ endif ~}
%{ if rate_limiting_enabled ~}
        <!-- Non-OpenAI request rate limiting (per subscription) -->
        <!-- Protects APIM compute and backends from request floods -->
        <!-- DocInt/Speech/Search/Storage use request-count limits (not token limits) -->
        <choose>
            <when condition="@(!context.Request.Url.Path.ToLower().Contains(&quot;openai&quot;) && !context.Request.Url.Path.ToLower().EndsWith(&quot;internal/apim-keys&quot;) && !context.Request.Url.Path.ToLower().EndsWith(&quot;internal/tenant-info&quot;))">
                <rate-limit-by-key
                    calls="${non_openai_requests_per_minute}"
                    renewal-period="60"
                    counter-key="@(context.Subscription.Id + &quot;-non-openai&quot;)"
                    increment-condition="@(context.Response.StatusCode >= 200)" />
            </when>
        </choose>
%{ endif ~}

        <!-- Path-based routing to appropriate backend service -->
        <choose>
%{ if apim_keys_endpoint_enabled ~}
            <!-- Internal endpoint: fetch APIM subscription keys from Key Vault -->
            <!-- Returns both primary and secondary keys + rotation metadata as JSON -->
            <!-- Available for ALL subscription-key tenants (keys stored in KV for all) -->
            <when condition="@(context.Request.Url.Path.ToLower().EndsWith(&quot;internal/apim-keys&quot;))">
                <!-- Only allow GET -->
                <choose>
                    <when condition="@(context.Request.Method != &quot;GET&quot;)">
                        <return-response>
                            <set-status code="405" reason="Method Not Allowed" />
                            <set-header name="Content-Type" exists-action="override">
                                <value>application/json</value>
                            </set-header>
                            <set-body>{"error":{"code":"MethodNotAllowed","message":"Only GET is supported."}}</set-body>
                        </return-response>
                    </when>
                </choose>
                <!-- Authenticate to Key Vault using APIM managed identity -->
                <authentication-managed-identity resource="https://vault.azure.net" output-token-variable-name="kv-token" ignore-error="false" />
                <!-- Fetch primary key from hub Key Vault -->
                <send-request mode="new" response-variable-name="kvPrimaryResp" timeout="10" ignore-error="true">
                    <set-url>@($"${keyvault_uri}secrets/${tenant_name}-apim-primary-key?api-version=7.4")</set-url>
                    <set-method>GET</set-method>
                    <set-header name="Authorization" exists-action="override">
                        <value>@("Bearer " + (string)context.Variables["kv-token"])</value>
                    </set-header>
                </send-request>
                <!-- Fetch secondary key from hub Key Vault -->
                <send-request mode="new" response-variable-name="kvSecondaryResp" timeout="10" ignore-error="true">
                    <set-url>@($"${keyvault_uri}secrets/${tenant_name}-apim-secondary-key?api-version=7.4")</set-url>
                    <set-method>GET</set-method>
                    <set-header name="Authorization" exists-action="override">
                        <value>@("Bearer " + (string)context.Variables["kv-token"])</value>
                    </set-header>
                </send-request>
%{ if key_rotation_enabled ~}
                <!-- Fetch rotation metadata from hub Key Vault (only for rotation-opted tenants) -->
                <send-request mode="new" response-variable-name="kvMetadataResp" timeout="10" ignore-error="true">
                    <set-url>@($"${keyvault_uri}secrets/${tenant_name}-apim-rotation-metadata?api-version=7.4")</set-url>
                    <set-method>GET</set-method>
                    <set-header name="Authorization" exists-action="override">
                        <value>@("Bearer " + (string)context.Variables["kv-token"])</value>
                    </set-header>
                </send-request>
%{ endif ~}
                <!-- Return explicit error if primary or secondary Key Vault reads failed -->
                <choose>
                    <when condition="@(
                        ((IResponse)context.Variables[&quot;kvPrimaryResp&quot;]) == null || ((IResponse)context.Variables[&quot;kvPrimaryResp&quot;]).StatusCode &gt;= 400 ||
                        ((IResponse)context.Variables[&quot;kvSecondaryResp&quot;]) == null || ((IResponse)context.Variables[&quot;kvSecondaryResp&quot;]).StatusCode &gt;= 400
                    )">
                        <return-response>
                            <set-status code="502" reason="Bad Gateway" />
                            <set-header name="Content-Type" exists-action="override">
                                <value>application/json</value>
                            </set-header>
                            <set-body>@{
                                var primaryResp = ((IResponse)context.Variables["kvPrimaryResp"]);
                                var secondaryResp = ((IResponse)context.Variables["kvSecondaryResp"]);

                                var result = new JObject(
                                    new JProperty("error", new JObject(
                                        new JProperty("code", "KeyVaultReadFailed"),
                                        new JProperty("message", "Failed to read APIM key secrets from Key Vault."),
                                        new JProperty("details", new JObject(
                                            new JProperty("primary_status", primaryResp == null ? 0 : primaryResp.StatusCode),
                                            new JProperty("secondary_status", secondaryResp == null ? 0 : secondaryResp.StatusCode)
                                        ))
                                    ))
                                );
                                return result.ToString();
                            }</set-body>
                        </return-response>
                    </when>
                </choose>
                <!-- Build JSON response -->
                <return-response>
                    <set-status code="200" reason="OK" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        var primaryBody = ((IResponse)context.Variables["kvPrimaryResp"])?.Body?.As<JObject>(preserveContent: true);
                        var secondaryBody = ((IResponse)context.Variables["kvSecondaryResp"])?.Body?.As<JObject>(preserveContent: true);

                        var primaryKey = primaryBody?["value"]?.ToString() ?? "";
                        var secondaryKey = secondaryBody?["value"]?.ToString() ?? "";

%{ if key_rotation_enabled ~}
                        var metadataBody = ((IResponse)context.Variables["kvMetadataResp"])?.Body?.As<JObject>(preserveContent: true);
                        var metadataRaw = metadataBody?["value"]?.ToString() ?? "{}";
                        JObject metadata;
                        try { metadata = JObject.Parse(metadataRaw); }
                        catch { metadata = new JObject(); }
%{ else ~}
                        var metadata = new JObject(
                            new JProperty("key_rotation_enabled", false),
                            new JProperty("message", "Automatic key rotation is not enabled for this tenant")
                        );
%{ endif ~}

                        var result = new JObject(
                            new JProperty("tenant", "${tenant_name}"),
                            new JProperty("primary_key", primaryKey),
                            new JProperty("secondary_key", secondaryKey),
                            new JProperty("rotation", metadata),
                            new JProperty("keyvault", new JObject(
                                new JProperty("uri", "${keyvault_uri}"),
                                new JProperty("primary_key_secret", "${tenant_name}-apim-primary-key"),
                                new JProperty("secondary_key_secret", "${tenant_name}-apim-secondary-key")
                            ))
                        );
                        return result.ToString();
                    }</set-body>
                </return-response>
            </when>
%{ endif ~}
%{ if tenant_info_enabled ~}
            <!-- Internal endpoint: return tenant configuration summary -->
            <!-- Reports deployed models with quotas and enabled services as JSON -->
            <!-- Data is baked in at Terraform render time - no external calls needed -->
            <when condition="@(context.Request.Url.Path.ToLower().EndsWith(&quot;internal/tenant-info&quot;))">
                <!-- Only allow GET -->
                <choose>
                    <when condition="@(context.Request.Method != &quot;GET&quot;)">
                        <return-response>
                            <set-status code="405" reason="Method Not Allowed" />
                            <set-header name="Content-Type" exists-action="override">
                                <value>application/json</value>
                            </set-header>
                            <set-body>{"error":{"code":"MethodNotAllowed","message":"Only GET is supported."}}</set-body>
                        </return-response>
                    </when>
                </choose>
                <!-- Return static tenant config (rendered at Terraform deploy time, not runtime) -->
                <return-response>
                    <set-status code="200" reason="OK" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>${jsonencode({
  tenant = tenant_name
  base_url = "${base_url}/${tenant_name}"
  models = [for m in model_deployments : {
    name              = m.name
    model_name        = m.model_name
    model_version     = m.model_version
    scale_type        = m.scale_type
    capacity_k_tpm    = m.capacity
    tokens_per_minute = m.capacity * 1000
    endpoints = {
      azure_openai = {
        endpoint    = "${base_url}/${tenant_name}"
        api_version = "2025-03-01-preview"
        url         = "${base_url}/${tenant_name}/openai/deployments/${m.name}/chat/completions?api-version=2025-03-01-preview"
      }
      openai_compatible = {
        base_url = "${base_url}/${tenant_name}/openai/v1"
        model    = m.name
        url      = "${base_url}/${tenant_name}/openai/v1/chat/completions"
      }
    }
  }]
  services = {
    openai = {
      enabled   = openai_enabled
      endpoints = openai_enabled ? {
        azure_openai      = "${base_url}/${tenant_name}"
        openai_compatible = "${base_url}/${tenant_name}/openai/v1"
        api_version       = "2025-03-01-preview"
      } : null
    }
    document_intelligence = {
      enabled  = document_intelligence_enabled
      endpoint = document_intelligence_enabled ? "${base_url}/${tenant_name}" : null
      example  = document_intelligence_enabled ? "${base_url}/${tenant_name}/documentintelligence/documentModels/prebuilt-layout:analyze?api-version=2024-11-30" : null
    }
    ai_search = {
      enabled  = ai_search_enabled
      endpoint = ai_search_enabled ? "${base_url}/${tenant_name}/ai-search" : null
      example  = ai_search_enabled ? "${base_url}/${tenant_name}/ai-search/indexes/{index-name}/docs/search?api-version=2024-07-01" : null
    }
    speech_services = {
      enabled      = speech_services_enabled
      stt_endpoint = speech_services_enabled ? "${base_url}/${tenant_name}/speech/recognition/conversation/cognitiveservices/v1?language=en-US" : null
      tts_endpoint = speech_services_enabled ? "${base_url}/${tenant_name}/cognitiveservices/v1" : null
    }
    storage = {
      enabled  = storage_enabled
      endpoint = storage_enabled ? "${base_url}/${tenant_name}/storage" : null
      example  = storage_enabled ? "${base_url}/${tenant_name}/storage/{container-name}/{blob-name}" : null
    }
  }
})}</set-body>
                </return-response>
            </when>
%{ endif ~}
%{ if document_intelligence_enabled ~}
            <!-- Document Intelligence requests: match documentintelligence, formrecognizer, or documentModels in path -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;documentintelligence&quot;) || context.Request.Url.Path.ToLower().Contains(&quot;formrecognizer&quot;) || context.Request.Url.Path.ToLower().Contains(&quot;documentmodels&quot;))">
                <set-backend-service backend-id="${tenant_name}-docint" />
                <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="msi-access-token" ignore-error="false" />
                <set-header name="Authorization" exists-action="override">
                    <value>@("Bearer " + (string)context.Variables["msi-access-token"])</value>
                </set-header>
                <set-header name="api-key" exists-action="delete" />
            </when>
%{ endif ~}
%{ if openai_enabled ~}
            <!-- OpenAI/AI Foundry requests: /openai/* -->
            <!-- Routes to shared AI Foundry Hub - tenant model deployments are on the Hub -->
            <!-- Deployment names on Hub are prefixed with tenant name (e.g., wlrs-gpt-4.1-mini) -->
            <!-- Supports both /deployments/ URL format and /v1/ body format -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;openai&quot;))">
                <set-backend-service backend-id="${tenant_name}-openai" />
                <!-- Validate /v1/ requests: must have valid JSON body with model field -->
                <choose>
                    <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;/v1/&quot;))">
                        <set-variable name="v1ModelValidation" value="@{
                            try {
                                var body = context.Request.Body.As&lt;JObject&gt;(preserveContent: true);
                                return body?[&quot;model&quot;]?.ToString() ?? &quot;&quot;;
                            } catch {
                                return &quot;__INVALID_JSON__&quot;;
                            }
                        }" />
                        <choose>
                            <when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;v1ModelValidation&quot;, &quot;&quot;) == &quot;__INVALID_JSON__&quot;)">
                                <return-response>
                                    <set-status code="400" reason="Bad Request" />
                                    <set-header name="Content-Type" exists-action="override">
                                        <value>application/json</value>
                                    </set-header>
                                    <set-body>{"error":{"code":"InvalidRequestBody","message":"Request body must be valid JSON for /v1/ endpoints."}}</set-body>
                                </return-response>
                            </when>
                            <when condition="@(string.IsNullOrEmpty(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;v1ModelValidation&quot;, &quot;&quot;)))">
                                <return-response>
                                    <set-status code="400" reason="Bad Request" />
                                    <set-header name="Content-Type" exists-action="override">
                                        <value>application/json</value>
                                    </set-header>
                                    <set-body>{"error":{"code":"MissingModel","message":"The 'model' field is required in the request body for /v1/ endpoints."}}</set-body>
                                </return-response>
                            </when>
                        </choose>
                    </when>
                </choose>
                <!-- Rewrite deployment name in URL to include tenant prefix -->
                <!-- Client sends: /openai/deployments/gpt-4.1-mini/chat/completions -->
                <!-- Backend receives: /openai/deployments/{tenant}-gpt-4.1-mini/chat/completions -->
                <!-- For /v1/ paths: URL does not contain deployment name, path forwarded as-is -->
                <!-- (e.g., /openai/v1/chat/completions → /openai/v1/chat/completions unchanged) -->
                <set-variable name="rewrittenPath" value="@{
                    var path = context.Request.Url.Path;
                    // Handle both with and without leading slash
                    var match = System.Text.RegularExpressions.Regex.Match(path, @&quot;/?openai/deployments/([^/]+)/(.*)&quot;);
                    if (match.Success) {
                        var deploymentName = match.Groups[1].Value;
                        var rest = match.Groups[2].Value;
                        return &quot;/openai/deployments/${tenant_name}-&quot; + deploymentName + &quot;/&quot; + rest;
                    }
                    // /v1/ paths: forward as-is (Azure OpenAI handles /openai/v1/ natively)
                    return &quot;/&quot; + path;
                }" />
                <rewrite-uri template="@((string)context.Variables[&quot;rewrittenPath&quot;])" copy-unmatched-params="true" />
                <!-- Detect streaming requests: stream:true in body means SSE response (not JSON) -->
                <!-- Read body as string first (preserveContent:true) to guarantee raw bytes are cached, -->
                <!-- then parse in-memory. This ensures piiInputContent can reliably read the same bytes. -->
                <set-variable name="isStream" value="@{
                    try {
                        var bodyStr = context.Request.Body.As&lt;string&gt;(preserveContent: true);
                        var body = JObject.Parse(bodyStr);
                        var streamVal = body?[&quot;stream&quot;];
                        if (streamVal != null) { return streamVal.Value&lt;bool&gt;(); }
                        return false;
                    } catch { return false; }
                }" />
%{ if pii_redaction_enabled ~}
                <!-- PII Anonymization via Azure Language Service -->
                <set-variable name="piiAnonymizationEnabled" value="true" />
                <set-variable name="piiInputContent" value="@(context.Request.Body.As&lt;string&gt;(preserveContent: true))" />
                <!-- PII Configuration: excluded categories and structural preservation -->
                <set-variable name="piiExcludedCategories" value="${jsonencode(pii_excluded_categories)}" />
                <set-variable name="piiPreserveJsonStructure" value="${pii_preserve_json_structure}" />
                <set-variable name="piiStructuralWhitelist" value="${jsonencode(pii_structural_whitelist)}" />
                <set-variable name="piiDetectionLanguage" value="${pii_detection_language}" />
                <!-- PII Fail-closed: block request if redaction fails (default: false = fail-open) -->
                <set-variable name="piiFailClosed" value="${pii_fail_closed}" />
                <!-- PII Scan Roles: message roles to include in redaction scanning (JSON array) -->
                <set-variable name="piiScanRoles" value='${pii_scan_roles}' />
                <!-- PII External Redaction: base URL of internal redaction Container App (empty = sync-only) -->
                <set-variable name="piiExternalRedactionUrl" value="${pii_external_redaction_url}" />
                <include-fragment fragment-id="pii-anonymization" />
                <!-- Apply the anonymized content back to the request body -->
                <set-body>@((string)context.Variables["piiAnonymizedContent"])</set-body>
%{ endif ~}
                <!-- For /v1/ requests: tenant-prefix the model field in the request body -->
                <!-- The "model" field on Azure OpenAI is a deployment name lookup key -->
                <!-- e.g., "gpt-4.1-mini" → "${tenant_name}-gpt-4.1-mini" -->
                <!-- Placed AFTER PII redaction set-body to avoid being overwritten -->
                <!-- Uses StartsWith guard to prevent double-prefixing -->
                <choose>
                    <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;/v1/&quot;))">
                        <set-body>@{
                            var body = context.Request.Body.As<JObject>(preserveContent: true);
                            var model = body["model"]?.ToString();
                            if (model != null)
                            {
                                if (!model.StartsWith("${tenant_name}-"))
                                {
                                    body["model"] = "${tenant_name}-" + model;
                                }
                            }
                            return body.ToString();
                        }</set-body>
                    </when>
                </choose>
                <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="msi-access-token" ignore-error="false" />
                <set-header name="Authorization" exists-action="override">
                    <value>@("Bearer " + (string)context.Variables["msi-access-token"])</value>
                </set-header>
                <set-header name="api-key" exists-action="delete" />
            </when>
%{ endif ~}
%{ if openai_enabled ~}
            <!-- Mistral AI requests -->
            <!-- Chat models are only supported on the OpenAI-compatible /openai/v1/chat/completions surface. -->
            <!-- Document AI models use the Mistral OCR /providers/mistral/azure/ocr surface. -->
            <!-- The legacy /providers/mistral/models/{model}/chat/completions alias is reserved for -->
            <!-- document models only and is rejected for chat models to preserve OpenAI-only token -->
            <!-- metrics, rate limiting, and a single stable client contract. -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;providers/mistral&quot;))">
                <set-backend-service backend-id="${tenant_name}-openai" />
                <set-variable name="mistralPathModel" value="@{
                    var match = System.Text.RegularExpressions.Regex.Match(context.Request.Url.Path, @&quot;/?providers/mistral/models/([^/]+)/&quot;);
                    return match.Success ? match.Groups[1].Value : string.Empty;
                }" />
                <choose>
                    <when condition="@{
                        var path = context.Request.Url.Path;
                        var pathModel = context.Variables.GetValueOrDefault<string>(&quot;mistralPathModel&quot;, string.Empty);
                        var isModelAlias = System.Text.RegularExpressions.Regex.IsMatch(path, @&quot;/?providers/mistral/models/[^/]+/chat/completions/?$&quot;, System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                        var isDocumentModel = !string.IsNullOrEmpty(pathModel) &amp;&amp; pathModel.ToLowerInvariant().StartsWith(&quot;mistral-document-ai-&quot;);
                        return isModelAlias &amp;&amp; !isDocumentModel;
                    }">
                        <return-response>
                            <set-status code="400" reason="Bad Request" />
                            <set-header name="Content-Type" exists-action="override">
                                <value>application/json</value>
                            </set-header>
                            <set-body>{"error":{"code":"InvalidMistralRoute","message":"Mistral chat models must be called via /openai/v1/chat/completions. The /providers/mistral/models/{model}/chat/completions route is reserved for document models only."}}</set-body>
                        </return-response>
                    </when>
                </choose>
                <set-variable name="rewrittenMistralPath" value="@{
                    var path = context.Request.Url.Path;
                    var pathLower = path.ToLowerInvariant();
                    var modelRouteMatch = System.Text.RegularExpressions.Regex.Match(path, @&quot;/?providers/mistral/models/([^/]+)/chat/completions/?$&quot;);

                    if (modelRouteMatch.Success)
                    {
                        var modelName = modelRouteMatch.Groups[1].Value;
                        if (modelName.ToLowerInvariant().StartsWith(&quot;mistral-document-ai-&quot;))
                        {
                            return &quot;/providers/mistral/azure/ocr&quot;;
                        }

                        return &quot;/openai/v1/chat/completions&quot;;
                    }

                    var providersIndex = pathLower.IndexOf(&quot;providers/mistral/&quot;);
                    if (providersIndex &gt;= 0)
                    {
                        var providerPath = path.Substring(providersIndex);
                        return providerPath.StartsWith(&quot;/&quot;) ? providerPath : &quot;/&quot; + providerPath;
                    }

                    return path.StartsWith(&quot;/&quot;) ? path : &quot;/&quot; + path;
                }" />
                <rewrite-uri template="@((string)context.Variables[&quot;rewrittenMistralPath&quot;])" copy-unmatched-params="true" />
                <set-body>@{
                    try {
                        var body = context.Request.Body.As<JObject>(preserveContent: true) ?? new JObject();
                        var pathModel = context.Variables.GetValueOrDefault<string>("mistralPathModel", string.Empty);
                        var rewrittenPath = context.Variables.GetValueOrDefault<string>("rewrittenMistralPath", string.Empty);
                        var requestModel = !string.IsNullOrEmpty(pathModel)
                            ? pathModel
                            : (body["model"]?.ToString() ?? string.Empty);

                        if (!string.IsNullOrEmpty(requestModel))
                        {
                            var tenantScopedModel = requestModel.StartsWith("${tenant_name}-")
                                ? requestModel
                                : "${tenant_name}-" + requestModel;

                            if (rewrittenPath == "/providers/mistral/azure/ocr")
                            {
                                body["model"] = tenantScopedModel;

                                if (body["document"] == null)
                                {
                                    JObject documentItem = null;
                                    var messages = body["messages"] as JArray;

                                    if (messages != null)
                                    {
                                        for (int i = 0; i &lt; messages.Count; i++)
                                        {
                                            var message = messages[i] as JObject;
                                            if (message == null)
                                            {
                                                continue;
                                            }

                                            var role = (message["role"]?.ToString() ?? string.Empty).ToLowerInvariant();
                                            if (role != &quot;user&quot;)
                                            {
                                                continue;
                                            }

                                            var contentItems = message["content"] as JArray;
                                            if (contentItems == null)
                                            {
                                                continue;
                                            }

                                            for (int contentIndex = 0; contentIndex &lt; contentItems.Count; contentIndex++)
                                            {
                                                var contentItem = contentItems[contentIndex] as JObject;
                                                if (contentItem == null)
                                                {
                                                    continue;
                                                }

                                                var contentType = (contentItem["type"]?.ToString() ?? string.Empty).ToLowerInvariant();
                                                if (contentType == &quot;document_url&quot; || contentType == &quot;image_url&quot;)
                                                {
                                                    documentItem = contentItem;
                                                    break;
                                                }
                                            }

                                            if (documentItem != null)
                                            {
                                                break;
                                            }
                                        }
                                    }

                                    if (documentItem != null)
                                    {
                                        var documentType = (documentItem["type"]?.ToString() ?? string.Empty).ToLowerInvariant();
                                        var document = new JObject();
                                        document["type"] = documentType;

                                        if (documentType == &quot;document_url&quot; && documentItem["document_url"] != null)
                                        {
                                            document["document_url"] = documentItem["document_url"];
                                        }
                                        else if (documentType == &quot;image_url&quot; && documentItem["image_url"] != null)
                                        {
                                            document["image_url"] = documentItem["image_url"];
                                        }

                                        var ocrBody = new JObject();
                                        ocrBody["model"] = tenantScopedModel;
                                        ocrBody["document"] = document;

                                        if (body["include_image_base64"] != null)
                                        {
                                            ocrBody["include_image_base64"] = body["include_image_base64"];
                                        }

                                        return ocrBody.ToString();
                                    }
                                }
                            }
                            else
                            {
                                body["model"] = tenantScopedModel;
                            }
                        }

                        return body.ToString();
                    } catch {
                        return context.Request.Body.As<string>(preserveContent: true);
                    }
                }</set-body>
                <authentication-managed-identity resource="https://cognitiveservices.azure.com" output-token-variable-name="msi-access-token" ignore-error="false" />
                <set-header name="Authorization" exists-action="override">
                    <value>@("Bearer " + (string)context.Variables["msi-access-token"])</value>
                </set-header>
                <set-header name="api-key" exists-action="delete" />
            </when>
%{ endif ~}
%{ if speech_services_enabled ~}
            <!-- Speech STT requests: speech/recognition -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;speech/recognition&quot;) || context.Request.Url.Path.ToLower().Contains(&quot;/stt/&quot;))">
                <set-backend-service backend-id="${tenant_name}-speech-stt" />
                <!-- Rewrite URI for custom subdomain: add /stt/ prefix -->
                <set-variable name="rewrittenSpeechPath" value="@{
                    var path = context.Request.Url.Path;
                    var pathLower = path.ToLower();
                    if (pathLower.StartsWith(&quot;/stt/&quot;)) {
                        return path;
                    }
                    return &quot;/stt/&quot; + path.TrimStart('/');
                }" />
                <rewrite-uri template="@((string)context.Variables[&quot;rewrittenSpeechPath&quot;])" copy-unmatched-params="true" />
                <!-- Backend has credentials configured - remove any incoming api-key/auth -->
                <set-header name="Authorization" exists-action="delete" />
                <set-header name="api-key" exists-action="delete" />
            </when>
            <!-- Speech TTS requests: /cognitiveservices/voices/list, /cognitiveservices/v1, speech/synthesis -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;cognitiveservices/voices&quot;) || context.Request.Url.Path.ToLower().Contains(&quot;cognitiveservices/v1&quot;) || context.Request.Url.Path.ToLower().Contains(&quot;speech/synthesis&quot;))">
                <set-backend-service backend-id="${tenant_name}-speech-tts" />
                <!-- Rewrite URI for custom subdomain: add /tts/ prefix -->
                <set-variable name="rewrittenSpeechPath" value="@{
                    var path = context.Request.Url.Path;
                    var pathLower = path.ToLower();
                    if (pathLower.StartsWith(&quot;/tts/&quot;)) {
                        return path;
                    }
                    return &quot;/tts/&quot; + path.TrimStart('/');
                }" />
                <rewrite-uri template="@((string)context.Variables[&quot;rewrittenSpeechPath&quot;])" copy-unmatched-params="true" />
                <!-- Backend has credentials configured - remove any incoming api-key/auth -->
                <set-header name="Authorization" exists-action="delete" />
                <set-header name="api-key" exists-action="delete" />
            </when>
%{ endif ~}
%{ if ai_search_enabled ~}
            <!-- AI Search requests: /ai-search/* -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;ai-search&quot;))">
                <set-backend-service backend-id="${tenant_name}-ai-search" />
                <!-- Strip /ai-search prefix from path before forwarding to backend -->
                <rewrite-uri template="@{
                    var path = context.Request.Url.Path;
                    var searchIndex = path.ToLower().IndexOf(&quot;ai-search&quot;);
                    if (searchIndex >= 0) {
                        return &quot;/&quot; + path.Substring(searchIndex + 9).TrimStart('/');
                    }
                    return path;
                }" copy-unmatched-params="true" />
                <authentication-managed-identity resource="https://search.azure.com" output-token-variable-name="msi-access-token" ignore-error="false" />
                <set-header name="Authorization" exists-action="override">
                    <value>@("Bearer " + (string)context.Variables["msi-access-token"])</value>
                </set-header>
                <set-header name="api-key" exists-action="delete" />
            </when>
%{ endif ~}
%{ if storage_enabled ~}
            <!-- Storage requests: /storage/* -->
            <!-- Path must start with /storage/ (after tenant prefix) to avoid false matches -->
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;/storage/&quot;) || context.Request.Url.Path.ToLower().EndsWith(&quot;/storage&quot;))">
                <set-backend-service backend-id="${tenant_name}-storage" />
                <authentication-managed-identity resource="https://storage.azure.com" output-token-variable-name="msi-access-token" ignore-error="false" />
                <set-header name="Authorization" exists-action="override">
                    <value>@("Bearer " + (string)context.Variables["msi-access-token"])</value>
                </set-header>
                <set-header name="api-key" exists-action="delete" />
            </when>
%{ endif ~}
            <!-- Default: Return 404 for unmatched paths -->
            <otherwise>
                <return-response>
                    <set-status code="404" reason="Not Found" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>{"error":{"code":"NotFound","message":"The requested path is not supported by this API."}}</set-body>
                </return-response>
            </otherwise>
        </choose>
    </inbound>
    <backend>
        <!-- Selective buffering: buffer only OpenAI requests for PII redaction and token inspection -->
        <!-- Timeout with tenant-specific backend overrides, https://learn.microsoft.com/en-us/azure/api-management/forward-request-policy#attributes -->
        <choose>
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;openai&quot;))">
                <forward-request buffer-request-body="true" timeout="${backend_timeout_seconds}" />
            </when>
            <otherwise>
                <forward-request buffer-request-body="false" timeout="${backend_timeout_seconds}" />
            </otherwise>
        </choose>
    </backend>
    <outbound>
        <base />
%{ if document_intelligence_enabled ~}
        <!-- Rewrite Operation-Location header to use App Gateway URL instead of direct backend URL -->
        <!-- This is critical for async operations (202 responses) to ensure clients poll through App Gateway -->
        <!-- Uses X-Forwarded-Host header from App Gateway if present (original client hostname) -->
        <choose>
            <when condition="@(context.Response.Headers.ContainsKey(&quot;Operation-Location&quot;))">
                <set-header name="Operation-Location" exists-action="override">
                    <value>@{
                        var operationLocation = context.Response.Headers.GetValueOrDefault("Operation-Location", "");
                        if (!string.IsNullOrEmpty(operationLocation))
                        {
                            // Replace the direct backend URL with gateway URL
                            // Pattern: https://{backend}.cognitiveservices.azure.com/{path}
                            // Replace with: https://{gateway-host}/{tenant-api}/{path}
                            var backendPattern = new System.Text.RegularExpressions.Regex(@"https://[^/]+\.cognitiveservices\.azure\.com/");
                            
                            // Use X-Forwarded-Host if present (from App Gateway), otherwise fall back to OriginalUrl.Host (direct APIM)
                            var gatewayHost = context.Request.Headers.GetValueOrDefault("X-Forwarded-Host", context.Request.OriginalUrl.Host);
                            var gatewayUrl = context.Request.OriginalUrl.Scheme + "://" + gatewayHost + "/" + context.Api.Path.TrimStart('/') + "/";
                            return backendPattern.Replace(operationLocation, gatewayUrl);
                        }
                        return operationLocation;
                    }</value>
                </set-header>
            </when>
        </choose>
%{ endif ~}
%{ if openai_enabled && usage_logging_enabled ~}
        <!-- OpenAI usage logging (skip for streaming - SSE responses are not parseable as JSON) -->
        <choose>
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;openai&quot;) &amp;&amp; !context.Variables.GetValueOrDefault&lt;bool&gt;(&quot;isStream&quot;, false))">
                <set-variable name="responseBody" value="@(context.Response.Body.As&lt;JObject&gt;(preserveContent: true))" />
                <!-- Set routing metadata for usage logging (single-backend for now) -->
                <set-variable name="backendId" value="@(&quot;${tenant_name}-openai&quot;)" />
                <set-variable name="routeLocation" value="@(&quot;canadaeast&quot;)" />
                <set-variable name="routeName" value="@(&quot;primary&quot;)" />
                <set-variable name="deploymentName" value="@{
                    // Prefer the inbound-extracted deploymentName (handles both /deployments/ and /v1/ formats)
                    var existing = context.Variables.GetValueOrDefault&lt;string&gt;(&quot;deploymentName&quot;, &quot;&quot;);
                    if (!string.IsNullOrEmpty(existing) &amp;&amp; existing != &quot;unknown&quot;) { return existing; }
                    // Fallback: extract from URL path for /deployments/ format
                    var path = context.Request.Url.Path;
                    var match = System.Text.RegularExpressions.Regex.Match(path, @&quot;/deployments/([^/]+)/&quot;);
                    return match.Success ? match.Groups[1].Value : &quot;unknown&quot;;
                }" />
                <include-fragment fragment-id="openai-usage-logging" />
            </when>
        </choose>
        <!-- Streaming usage logging - SSE responses cannot be parsed as JObject, -->
        <!-- Token metrics already emitted by global policy azure-openai-emit-token-metric in inbound -->
        <!-- This trace logs request metadata to App Insights for streaming calls -->
        <choose>
            <when condition="@(context.Request.Url.Path.ToLower().Contains(&quot;openai&quot;) &amp;&amp; context.Variables.GetValueOrDefault&lt;bool&gt;(&quot;isStream&quot;, false))">
                <set-variable name="backendId" value="@(&quot;${tenant_name}-openai&quot;)" />
                <set-variable name="routeLocation" value="@(&quot;canadaeast&quot;)" />
                <set-variable name="routeName" value="@(&quot;primary&quot;)" />
                <set-variable name="deploymentName" value="@{
                    var existing = context.Variables.GetValueOrDefault&lt;string&gt;(&quot;deploymentName&quot;, &quot;&quot;);
                    if (!string.IsNullOrEmpty(existing) &amp;&amp; existing != &quot;unknown&quot;) { return existing; }
                    var path = context.Request.Url.Path;
                    var match = System.Text.RegularExpressions.Regex.Match(path, @&quot;/deployments/([^/]+)/&quot;);
                    return match.Success ? match.Groups[1].Value : &quot;unknown&quot;;
                }" />
                <trace source="openai-streaming" severity="information">
                    <message>OpenAI Streaming Request</message>
                    <metadata name="event-type" value="openai-streaming" />
                    <metadata name="request-id" value="@(context.RequestId.ToString())" />
                    <metadata name="timestamp" value="@(DateTime.UtcNow.ToString(&quot;o&quot;))" />
                    <metadata name="subscription-id" value="@(context.Subscription?.Id ?? &quot;Portal-Admin&quot;)" />
                    <metadata name="tenant-id" value="@(context.Request.Headers.GetValueOrDefault(&quot;X-Tenant-Id&quot;, &quot;unknown&quot;))" />
                    <metadata name="backend-id" value="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;backendId&quot;, &quot;unknown&quot;))" />
                    <metadata name="deployment-name" value="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;deploymentName&quot;, &quot;unknown&quot;))" />
                    <metadata name="route-location" value="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;routeLocation&quot;, &quot;unknown&quot;))" />
                    <metadata name="is-streaming" value="true" />
                </trace>
            </when>
        </choose>
%{ endif ~}
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
