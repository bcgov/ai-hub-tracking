# Required
PII_LANGUAGE_ENDPOINT=https://<your-language-service>.cognitiveservices.azure.com

# Optional — these are the defaults shown
PII_PER_BATCH_TIMEOUT_SECONDS=10
PII_TOTAL_PROCESSING_TIMEOUT_SECONDS=55
PII_MAX_CONCURRENT_BATCHES=15
PII_MAX_BATCH_CONCURRENCY=3
PII_MAX_DOC_CHARS=5000
PII_MAX_DOCS_PER_CALL=5
PII_LOG_LEVEL=INFO
PII_LANGUAGE_API_VERSION=2024-11-01