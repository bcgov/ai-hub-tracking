{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "bash .github/hooks/scripts/guard-destructive.sh",
        "powershell": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/guard-destructive.ps1",
        "cwd": ".",
        "timeoutSec": 10,
        "comment": "Block dangerous bash commands (force-push, hard-reset, rm -rf on infra dirs)"
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "bash .github/hooks/scripts/post-tool-use.sh",
        "powershell": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/post-tool-use.ps1",
        "cwd": ".",
        "timeoutSec": 240,
        "comment": "Mirror .pre-commit-config.yaml hooks: lint + format:check + tests + docs check after every file edit or create"
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "bash .github/hooks/scripts/post-tool-use.sh",
        "powershell": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/post-tool-use.ps1",
        "cwd": ".",
        "timeoutSec": 240,
        "comment": "Final quality gate sweep at session end — catches any edits that slipped past postToolUse"
      }
    ]
  }
}
