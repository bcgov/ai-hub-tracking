# Tenant Onboarding Portal – local development environment
# Copy to .env and fill in your values.
#
# Dev auto-login mode (no Keycloak needed):
#   Leave PORTAL_OIDC_DISCOVERY_URL empty. The app creates a synthetic session
#   for dev@example.com with the portal-admin role. All pages work without a
#   real Keycloak server or Azure Storage account.

# ── App ─────────────────────────────────────────────────────────────────────
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
PORTAL_SECRET_KEY=change-me-at-least-32-chars-long-here
PORTAL_DEBUG=false

# ── Keycloak OIDC ────────────────────────────────────────────────────────────
# Leave empty to enable dev auto-login (no OIDC flow, no Keycloak needed).
PORTAL_OIDC_DISCOVERY_URL=
PORTAL_OIDC_CLIENT_ID=
PORTAL_OIDC_CLIENT_SECRET=
# Optional – defaults to PORTAL_OIDC_CLIENT_ID when blank.
PORTAL_OIDC_CLIENT_AUDIENCE=
# Keycloak role that grants admin access. Must exist in realm_access.roles
# or resource_access.<client_id>.roles in the access_token.
PORTAL_OIDC_ADMIN_ROLE=portal-admin

# ── Azure Table Storage ──────────────────────────────────────────────────────
# Leave both empty to use in-memory storage (data lost on restart).
# Use the account URL for managed-identity (passwordless) auth in production.
PORTAL_TABLE_STORAGE_ACCOUNT_URL=
# Alternative: connection string auth for local dev with a real storage account.
PORTAL_TABLE_STORAGE_CONNECTION_STRING=

# ── Admin allow-list (fallback) ───────────────────────────────────────────────
# Comma-separated @gov.bc.ca emails. Only checked when the token has no admin
# role. Role-based check (PORTAL_OIDC_ADMIN_ROLE) takes precedence.
PORTAL_ADMIN_EMAILS=
