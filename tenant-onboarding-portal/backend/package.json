{
  "name": "tenant-onboarding-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:frontend:bundle": "cd ../frontend && npm run build",
    "build:frontend:sync": "node scripts/sync-frontend-dist.cjs",
    "build:frontend": "npm run build:frontend:bundle && npm run build:frontend:sync",
    "build:all": "npm run build:frontend && npm run build",
    "e2e": "npm run build:all && playwright test",
    "e2e:dev": "playwright test -c playwright.dev.config.ts",
    "e2e:serve": "node scripts/start-e2e-server.cjs",
    "start": "node dist/main.js",
    "start:dev": "node --env-file-if-exists=.env ./node_modules/tsx/dist/cli.mjs watch src/main.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write",
    "prettier:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "npm run prettier -- \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "npm run prettier:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.10.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "nest-winston": "^1.10.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "winston": "^3.19.0"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/testing": "^11.1.17",
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
