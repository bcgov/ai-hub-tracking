# Tenant Onboarding Portal – local development environment
# Copy to .env and fill in your values.
#
# Dev session mode (no Keycloak needed):
#   Leave PORTAL_OIDC_DISCOVERY_URL empty. The backend auto-establishes a mock
#   admin session and keeps auth state in memory.

# ── App ─────────────────────────────────────────────────────────────────────
PORTAL_DEBUG=false
# Optional comma-separated allowlist for cross-origin browser access.
# Leave blank to reflect the caller origin.
# Example: http://localhost:5173,http://127.0.0.1:5173
PORTAL_CORS_ALLOWED_ORIGINS=

# ── Keycloak OIDC ────────────────────────────────────────────────────────────
# Leave empty to enable dev session mode (no OIDC flow, no Keycloak needed).
PORTAL_OIDC_DISCOVERY_URL=
PORTAL_OIDC_CLIENT_ID=
# Keycloak confidential client secret (required when PORTAL_OIDC_DISCOVERY_URL is set).
PORTAL_OIDC_CLIENT_SECRET=
# Optional – defaults to PORTAL_OIDC_CLIENT_ID when blank.
PORTAL_OIDC_CLIENT_AUDIENCE=
# Keycloak role that grants admin access. Must exist in realm_access.roles
# or resource_access.<client_id>.roles in the access_token.
PORTAL_OIDC_ADMIN_ROLE=portal-admin

# ── Azure Table Storage ──────────────────────────────────────────────────────
# Leave both empty to use in-memory storage for tenant data and portal sessions
# (data lost on restart).
# Use the account URL for managed-identity (passwordless) auth in production.
# The portal stores auth state in the separate Azure Table `TenantPortalSessions`.
PORTAL_TABLE_STORAGE_ACCOUNT_URL=
# Alternative: connection string auth for local dev with a real storage account.
PORTAL_TABLE_STORAGE_CONNECTION_STRING=
